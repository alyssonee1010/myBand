# Database
DATABASE_URL="postgresql://user:password@localhost:5432/myband_dev"

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRY=7d

# App URLs
APP_BASE_URL="http://localhost:3000"

# Email verification
MAIL_FROM="MyBand <yourgmail@gmail.com>"
GMAIL_APP_USER="yourgmail@gmail.com"
GMAIL_APP_PASSWORD="your-gmail-app-password"
EMAIL_VERIFICATION_TTL_HOURS=24
EMAIL_VERIFICATION_COOLDOWN_SECONDS=30

# File Upload
MAX_FILE_SIZE=10485760
MAX_IMAGE_SIZE=5242880
# Local development default. On Railway, mount a volume and set this to /app/uploads
UPLOAD_DIR=./uploads
# Keep uploaded files private and stream them through the authenticated /file route
EXPOSE_UPLOADS_PUBLICLY=false

# CORS
FRONTEND_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost,capacitor://localhost,ionic://localhost"
